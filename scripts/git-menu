#!/bin/bash

# Verify gum is installed
if ! command -v gum &> /dev/null; then
    echo "gum is not installed. Installing..."
    if ! command -v brew &> /dev/null; then
        echo "Homebrew is not installed. Please install Homebrew first."
        exit 1
    fi
    if ! brew install gum;

    then
        echo "Failed to install gum. Please check your internet connection or try again later."
        exit 1
    fi
fi


switch() {
    BRANCH=$(git branch --format='%(refname:short)' | grep -v "$(git branch --show-current)" | gum choose --header "Select a branch:" || true)
    if [ -n "$BRANCH" ]; then
        git checkout "$BRANCH"
    fi
}

absorb() {
    git add . 
    MESSAGE=$(git commit -m "$(gum input --placeholder "Commit message")" || true)
    if [ -n "$MESSAGE" ]; then
        git commit -m "$MESSAGE"
        gum confirm "Push changes?" && git push
    fi
}

sync() {
    CURRENT_BRANCH=$(git branch --show-current)
    DEFAULT_BRANCH=$(git remote show origin | sed -n '/HEAD branch/s/.*: //p') || {
        echo "Failed to determine default branch. Please check your git configuration." 2>&1
        return
    }

    if [[ "$CURRENT_BRANCH" == "$DEFAULT_BRANCH" ]]; then
        git pull

        return
    fi

    git fetch origin "$DEFAULT_BRANCH" || {
        echo "Failed to fetch from origin. Please check your network connection and remote repository." 2>&1
        return
    }

    if [ "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ]; then
        COMMAND=$(gum choose --header "Select sync method:" "Merge (git pull)" "Rebase (git pull --rebase)" || true)
        if [ -n "$COMMAND" ]; then
            if [[ $COMMAND == "Merge"* ]]; then
                git merge "$DEFAULT_BRANCH"
            elif [[ $COMMAND == "Rebase"* ]]; then
                git rebase -i "$DEFAULT_BRANCH"
            fi
        fi
    fi
}

if [[ $1 == switch ]]; then
    switch
    return
fi

if [[ $1 == absorb ]]; then
    absorb
    return
fi

if [[ $1 == sync ]]; then
    sync
    return
fi

LIST=$(cat <<END
Sync:!f sync
Create:!f git chb
Switch:!f switch
Checkout-without-hooks:!f git checkout-no-hooks
Modify:!f git amend
Absorb-and-modify:!f git qaemnd
Yolo:!f git yolo
Undo:!f git undo
Redo:!f git redo
Cleanup (removed merged branches):!f git cleanup
PR:github-create-pull-request
Find:github-pr-from-commit
Request re-review:github-pr-re-review
END
)

# cut is a Unix utility that splits each input line into fields.
# -d ':'    # use a colon character as the field **delimiter**
# -f 1      # select the **first** field from each line
KEY=$(echo "$LIST" | cut -d':' -f1 | gum choose --header "Select what to run:")

if [ -n "$KEY" ]; then
    COMMAND=$(echo "$LIST" | grep $KEY | cut -d':' -f2)

    if [ -n "$COMMAND" ]; then
        if [[ $COMMAND == !f* ]]; then
            eval "${COMMAND:3}"
        else
            eval "$HOME/.scripts/$COMMAND"
        fi
    fi
fi
