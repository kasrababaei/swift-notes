#!/bin/bash

# Verify gum is installed
if ! command -v gum &> /dev/null; then
    echo "gum is not installed. Installing..."
    if ! command -v brew &> /dev/null; then
        echo "Homebrew is not installed. Please install Homebrew first."
        exit 1
    fi
    if ! brew install gum;

    then
        echo "Failed to install gum. Please check your internet connection or try again later."
        exit 1
    fi
fi


sync() {
    CURRENT_BRANCH=$(git branch --show-current)
    DEFAULT_BRANCH=$(git remote show origin | sed -n '/HEAD branch/s/.*: //p') || {
        echo "Failed to determine default branch. Please check your git configuration." 2>&1
        return
    }

    if [[ "$CURRENT_BRANCH" == "$DEFAULT_BRANCH" ]]; then
        git pull

        return
    fi

    git fetch origin "$DEFAULT_BRANCH":"$DEFAULT_BRANCH" || {
        echo "Failed to fetch $DEFAULT_BRANCH from origin. Please check your network connection and remote repository." 2>&1
        return
    }

    if [ "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ]; then
        COMMAND=$(gum choose --header "Select sync method:" "Merge (git pull)" "Rebase (git pull --rebase)" || true)
        if [ -n "$COMMAND" ]; then
            if [[ $COMMAND == "Merge"* ]]; then
                git merge "$DEFAULT_BRANCH"
            elif [[ $COMMAND == "Rebase"* ]]; then
                git rebase -i "$DEFAULT_BRANCH"
            fi
        fi
    fi
}

create() {
    SUFFIX="dev/$(whoami)"
    DEFAULT_BRANCH=$(git remote show origin | sed -n '/HEAD branch/s/.*: //p') || {
        echo "Failed to determine default branch. Please check your git configuration." 2>&1
        return
    }
    CURRENT_BRANCH=$(git branch --show-current)
    BASE_BRANCH="$DEFAULT_BRANCH"

    if [ -n "$1" ]; then
        BRANCH_NAME="$SUFFIX/$1"
        
        if [ -n "$2" ]; then
            if [[ "$2" == "-c" ]]; then
                BASE_BRANCH="$CURRENT_BRANCH"
            else
                BASE_BRANCH="$2"
            fi
        fi

        git branch "$BRANCH_NAME" "origin/$BASE_BRANCH"
        git checkout "$BRANCH_NAME"
    else
        BRANCH_NAME=$(gum input --placeholder "Branch name")

        if [ -n "$BRANCH_NAME" ]; then
            git branch "$BRANCH_NAME" "origin/$BASE_BRANCH"
            git checkout "$BRANCH_NAME"
        fi
    fi

    return
}

if [[ $1 == create ]]; then
    create "$2" "$3"
    return
fi

submit() {
    CURRENT_BRANCH=$(git branch --show-current)
    git push --set-upstream origin "$CURRENT_BRANCH" 1>/dev/null || {
        echo "Failed to push to origin. Please check your network connection and remote repository." 2>&1
        return
    }

    PR_NUMBER=$(gh pr list --head "$CURRENT_BRANCH" --state all --json number --jq '.[0].number')

    if [[ -z "$PR_NUMBER" ]]; then
        gum confirm "Create PR on GitHub?" && github-create-pull-request
    fi
}

if [[ $1 == submit ]]; then
    submit
    return
fi

switch() {
    if [[ "$1" == "-" ]]; then
        git checkout -
        return
    fi

    BRANCH=$(git branch --format='%(refname:short)' | grep -v "$(git branch --show-current)" | gum choose --header "Select a branch:" || true)
    if [ -n "$BRANCH" ]; then
        git checkout "$BRANCH"
    fi
}

if [[ $1 == switch ]]; then
    switch "$2"
    return
fi

absorb() {
    local MESSAGE="$1"

    git add .

    if [ -n "$MESSAGE" ]; then
        git commit -m "$MESSAGE" 2>&1 || {
            echo "Failed to commit changes. Please check your git status and try again." 2>&1
            return
        }

        gum confirm "Push changes?" && submit
    else
        MESSAGE=$(git commit -m "$(gum input --placeholder "Commit message")" || true)
        if [ -n "$MESSAGE" ]; then
            git commit -m "$MESSAGE"
            gum confirm "Push changes?" && submit
        fi
    fi
}

modify() {
    git add .
    git commit --amend --no-edit
}

if [[ $1 == modify ]]; then
    modify
    return
fi

stack() {
    DEFAULT_BRANCH=$(git remote show origin | sed -n '/HEAD branch/s/.*: //p') || {
        echo "Failed to determine default branch. Please check your git configuration." 2>&1
        return
    }
    STACK="$DEFAULT_BRANCH"

    while read -r COMMIT; do
        LIST=$(git branch --format='%(refname:short)' --contains "$COMMIT")

        while IFS=$'\n' read -r BRANCH; do
            STACK="$STACK"$'\n'"$BRANCH"
        done <<< "$LIST"
    done < <(git log --format='%H' "$DEFAULT_BRANCH"..HEAD)

    BRANCH=$(echo "${STACK}" | gum choose --header "Stack:" || true)
    return
}

list() {
    git branch --format='%(refname:short)'
}

delete() {
    CURRENT_BRANCH=$(git branch --show-current)
    LIST=""

    while read -r BRANCH; do
        if [ "$BRANCH" != "$CURRENT_BRANCH" ]; then
            LIST="$LIST"$'\n'"$BRANCH"
        fi
    done < <(git branch --format='%(refname:short)')

    BRANCH=$(echo "${LIST}" | gum choose --header "Select a branch to delete:" || true)
    
    if [ -n "$BRANCH" ]; then
        gum confirm "Are you sure you want to delete '$BRANCH'?" && git branch -D "$BRANCH"
    fi
}

if [[ $1 == sync ]]; then
    sync "$2"
    return
fi

if [[ $1 == absorb ]]; then
    absorb "$2"
    return
fi

if [[ $1 == stack ]]; then
    stack
    return
fi

if [[ $1 == list ]]; then
    list
    return
fi

if [[ $1 == delete ]]; then
    delete
    return
fi

LIST=$(cat <<END
Sync:!f sync
Create:!f create
Submit:!f submit
Switch:!f switch
Switch W/O Hooks:!f git checkout-no-hooks
Stack:!f stack
List:!f list
Delete:!f delete
Modify:!f modify
Absorb:!f absorb
Absorb + Modify:!f git qaemnd
Yolo:!f git yolo
Undo:!f git undo
Redo:!f git redo
Cleanup (removed merged branches):!f git cleanup
PR:github-create-pull-request
Find:github-pr-from-commit
Request re-review:github-pr-re-review
END
)

# cut is a Unix utility that splits each input line into fields.
# -d ':'    # use a colon character as the field **delimiter**
# -f 1      # select the **first** field from each line
KEY=$(echo "$LIST" | cut -d':' -f1 | gum choose --header "Select what to run:")

if [ -n "$KEY" ]; then
    COMMAND=$(echo "$LIST" | grep $KEY | cut -d':' -f2)

    if [ -n "$COMMAND" ]; then
        if [[ $COMMAND == !f* ]]; then
            eval "${COMMAND:3}"
        else
            eval "$HOME/.scripts/$COMMAND"
        fi
    fi
fi
